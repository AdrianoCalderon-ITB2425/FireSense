<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Espurna IoT — Collserola Fire Detection</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap');
:root{
  --cyan:#00e5ff;--green:#00ff88;--orange:#ff6d00;--red:#ff1744;--amber:#ffab40;
  --bg:#020c10;--panel:#041520;--border:#0a3a4a;
  --neon-cyan:0 0 4px #00e5ff,0 0 12px #00e5ff,0 0 28px rgba(0,229,255,.5);
  --neon-green:0 0 4px #00ff88,0 0 12px #00ff88,0 0 28px rgba(0,255,136,.5);
  --neon-red:0 0 4px #ff1744,0 0 12px #ff1744,0 0 28px rgba(255,23,68,.5);
  --neon-amber:0 0 4px #ffab40,0 0 12px #ffab40,0 0 28px rgba(255,171,64,.5);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);font-family:'Share Tech Mono',monospace;min-height:100vh;display:flex;flex-direction:column;
  background-image:linear-gradient(rgba(0,229,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.018) 1px,transparent 1px);
  background-size:40px 40px;}
.hdr{padding:18px 32px 12px;display:flex;flex-direction:column;align-items:center;gap:4px;
  background:linear-gradient(180deg,rgba(0,229,255,.04) 0%,transparent 100%);}
.hdr-tag{font-size:10px;letter-spacing:.35em;color:var(--cyan);opacity:.7;text-transform:uppercase;}
.hdr-title{font-family:'Rajdhani',sans-serif;font-size:clamp(22px,2.6vw,36px);font-weight:700;color:#e0f7ff;
  letter-spacing:.08em;text-transform:uppercase;text-shadow:var(--neon-cyan);}
.hdr-sub{font-size:10px;letter-spacing:.2em;color:rgba(0,229,255,.5);}
.hdr-line{width:100%;height:1px;background:linear-gradient(90deg,transparent,var(--cyan),transparent);opacity:.3;margin-top:3px;}
.status-bar{display:flex;justify-content:space-between;align-items:center;padding:7px 20px;
  background:rgba(0,229,255,.025);border-bottom:1px solid var(--border);font-size:9.5px;
  letter-spacing:.08em;color:rgba(0,229,255,.5);flex-wrap:wrap;gap:8px;}
.si{display:flex;align-items:center;gap:6px;}
.sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.dot-g{background:var(--green);box-shadow:var(--neon-green);animation:blink 2s ease-in-out infinite;}
.dot-a{background:var(--amber);box-shadow:var(--neon-amber);}
.dot-r{background:var(--red);box-shadow:var(--neon-red);animation:blink .8s ease-in-out infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
.refresh-btn{background:rgba(0,229,255,.06);border:1px solid rgba(0,229,255,.25);color:var(--cyan);
  font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:.1em;padding:5px 14px;
  cursor:pointer;transition:all .2s;}
.refresh-btn:hover{background:rgba(0,229,255,.14);box-shadow:var(--neon-cyan);}
.main{display:grid;grid-template-columns:1fr 330px;gap:14px;padding:14px 20px;flex:1;}
.map-card{background:var(--panel);border:1px solid var(--border);border-radius:2px;position:relative;
  overflow:hidden;min-height:520px;display:flex;flex-direction:column;}
.map-card::before,.map-card::after,.map-card .br,.map-card .bl{content:'';position:absolute;
  width:14px;height:14px;border-color:var(--cyan);border-style:solid;opacity:.7;z-index:500;}
.map-card::before{top:-1px;left:-1px;border-width:2px 0 0 2px;box-shadow:-2px -2px 6px rgba(0,229,255,.3);}
.map-card::after{top:-1px;right:-1px;border-width:2px 2px 0 0;box-shadow:2px -2px 6px rgba(0,229,255,.3);}
.map-card .br{bottom:-1px;right:-1px;border-width:0 2px 2px 0;box-shadow:2px 2px 6px rgba(0,229,255,.3);}
.map-card .bl{bottom:-1px;left:-1px;border-width:0 0 2px 2px;box-shadow:-2px 2px 6px rgba(0,229,255,.3);}
.map-label{position:absolute;top:10px;left:12px;z-index:400;font-family:'Rajdhani',sans-serif;
  font-size:12px;font-weight:700;color:var(--cyan);letter-spacing:.12em;text-transform:uppercase;
  background:rgba(2,12,16,.92);padding:4px 10px;border:1px solid rgba(0,229,255,.3);
  pointer-events:none;text-shadow:var(--neon-cyan);}
.edit-toggle{position:absolute;top:10px;right:12px;z-index:400;background:rgba(2,12,16,.92);
  border:1px solid rgba(0,229,255,.3);color:rgba(0,229,255,.6);font-family:'Share Tech Mono',monospace;
  font-size:9px;letter-spacing:.1em;padding:6px 12px;cursor:pointer;transition:all .2s;}
.edit-toggle:hover{border-color:rgba(0,229,255,.6);color:var(--cyan);}
.edit-toggle.active{background:rgba(255,171,64,.1);border-color:var(--amber);color:var(--amber);}
.edit-banner{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);z-index:400;
  background:rgba(2,12,16,.95);border:1px solid rgba(255,171,64,.5);padding:6px 18px;
  font-size:9px;letter-spacing:.12em;color:var(--amber);white-space:nowrap;display:none;}
.edit-banner.visible{display:block;}
/* Map container */
.map-wrap{position:relative;flex:1;min-height:520px;}
#map{width:100%;height:100%;min-height:520px;}
/* Canvas injected inside leaflet-container via JS — z-index above panes (400+) but below popups (700+) */
#pktCanvas{position:absolute;top:0;left:0;pointer-events:none;z-index:650;}
.leaflet-container{background:#020c10!important;}
.leaflet-tile{filter:brightness(.5) saturate(.55) hue-rotate(165deg) sepia(.25);}
.leaflet-control-zoom a{background:rgba(4,21,32,.95)!important;border-color:var(--border)!important;
  color:var(--cyan)!important;font-family:'Share Tech Mono',monospace!important;}
.leaflet-control-zoom a:hover{background:rgba(0,229,255,.12)!important;}
.leaflet-control-attribution{background:rgba(2,12,16,.8)!important;color:rgba(0,229,255,.3)!important;font-size:8px!important;}
.leaflet-control-attribution a{color:rgba(0,229,255,.4)!important;}
/* Neon node icons */
.node-icon-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
.node-pulse-ring{position:absolute;width:34px;height:34px;border-radius:50%;border:2px solid var(--green);
  animation:ringPulse 2.4s ease-out infinite;}
@keyframes ringPulse{0%{transform:scale(.5);opacity:.9}100%{transform:scale(1.8);opacity:0}}
.node-dot{width:14px;height:14px;border-radius:50%;background:rgba(0,255,136,.15);
  border:2.5px solid var(--green);box-shadow:var(--neon-green);z-index:1;}
.node-dot.warn{border-color:var(--amber);background:rgba(255,171,64,.15);box-shadow:var(--neon-amber);}
.node-dot.crit{border-color:var(--red);background:rgba(255,23,68,.15);box-shadow:var(--neon-red);}
.gw-icon-wrap{display:flex;align-items:center;justify-content:center;position:relative;}
.gw-hex-icon{width:28px;height:28px;background:rgba(0,229,255,.12);border:2px solid var(--cyan);
  clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  display:flex;align-items:center;justify-content:center;box-shadow:var(--neon-cyan);
  animation:gwGlow 3s ease-in-out infinite;}
@keyframes gwGlow{0%,100%{filter:brightness(1)}50%{filter:brightness(1.5)}}
.gw-dot{width:7px;height:7px;border-radius:50%;background:var(--cyan);box-shadow:var(--neon-cyan);}
/* Popups */
.leaflet-popup-content-wrapper{background:rgba(4,21,32,.97)!important;border:1px solid var(--cyan)!important;
  border-radius:2px!important;box-shadow:0 0 24px rgba(0,229,255,.25)!important;
  color:#e0f7ff!important;font-family:'Share Tech Mono',monospace!important;}
.leaflet-popup-tip-container{display:none;}
.leaflet-popup-content{margin:12px 16px!important;font-size:10px!important;}
.popup-title{font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;color:var(--cyan);
  letter-spacing:.1em;margin-bottom:8px;text-shadow:var(--neon-cyan);}
.popup-row{display:flex;justify-content:space-between;gap:20px;margin-bottom:4px;
  color:rgba(0,229,255,.55);font-size:9.5px;}
.popup-val{color:#e0f7ff;font-weight:bold;}
.popup-coords{margin-top:8px;padding-top:6px;border-top:1px solid rgba(0,229,255,.15);
  font-size:8px;color:rgba(0,229,255,.35);letter-spacing:.05em;}
/* Right panel */
.right-panel{display:flex;flex-direction:column;gap:10px;}
.card{background:var(--panel);border:1px solid var(--border);border-radius:2px;padding:13px 15px;position:relative;}
.card-l-cyan::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;
  background:var(--cyan);box-shadow:var(--neon-cyan);}
.card-l-green::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;
  background:var(--green);box-shadow:var(--neon-green);}
.card-title{font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;margin-bottom:10px;padding-left:8px;display:flex;align-items:center;gap:7px;}
.ct-c{color:var(--cyan);text-shadow:var(--neon-cyan);}
.ct-g{color:var(--green);text-shadow:var(--neon-green);}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);
  box-shadow:var(--neon-green);animation:blink 1.4s ease-in-out infinite;}
.drow{display:flex;justify-content:space-between;align-items:center;padding:5px 8px;
  border-bottom:1px solid rgba(0,229,255,.05);font-size:9px;letter-spacing:.07em;color:rgba(0,229,255,.5);}
.drow:last-child{border-bottom:none;}
.dval{color:#e0f7ff;font-size:10px;}
.dval.g{color:var(--green);text-shadow:0 0 8px rgba(0,255,136,.4);}
.dval.r{color:var(--red);text-shadow:0 0 8px rgba(255,23,68,.4);}
.dval.a{color:var(--amber);text-shadow:0 0 8px rgba(255,171,64,.4);}
.node-sel{display:flex;gap:4px;margin-bottom:10px;}
.nbtn{flex:1;background:rgba(0,0,0,.3);border:1px solid rgba(0,229,255,.18);
  color:rgba(0,229,255,.45);font-family:'Share Tech Mono',monospace;font-size:8.5px;
  letter-spacing:.05em;padding:5px 2px;cursor:pointer;text-align:center;
  transition:all .2s;border-radius:1px;}
.nbtn:hover{border-color:rgba(0,229,255,.5);color:var(--cyan);}
.nbtn.active{background:rgba(0,229,255,.1);border-color:var(--cyan);color:var(--cyan);
  box-shadow:inset 0 0 10px rgba(0,229,255,.1),0 0 6px rgba(0,229,255,.2);}
.nbtn.off{border-color:rgba(40,40,40,.5);color:rgba(60,60,60,.7);cursor:default;pointer-events:none;}
.mbig{text-align:center;padding:8px 0;border-bottom:1px solid rgba(0,229,255,.06);margin-bottom:8px;}
.mbig-lbl{font-size:8px;letter-spacing:.18em;color:rgba(0,229,255,.4);text-transform:uppercase;margin-bottom:2px;}
.mbig-val{font-family:'Rajdhani',sans-serif;font-size:46px;font-weight:700;line-height:1;}
.mbig-unit{font-size:11px;color:rgba(0,229,255,.5);margin-top:1px;}
.mrow{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px;}
.mmini{background:rgba(0,0,0,.22);border:1px solid rgba(0,229,255,.08);padding:8px 10px;text-align:center;}
.mmini-lbl{font-size:7.5px;letter-spacing:.12em;color:rgba(0,229,255,.4);text-transform:uppercase;margin-bottom:2px;}
.mmini-val{font-family:'Rajdhani',sans-serif;font-size:24px;font-weight:700;line-height:1;}
.mmini-unit{font-size:8px;color:rgba(0,229,255,.4);margin-top:1px;}
.vt{color:#ff8f00;}.vt.hot{color:#ff1744;text-shadow:var(--neon-red);}
.vh{color:#00b8d4;}.vs{color:#4caf50;}.vs.dry{color:#ff6d00;}
.alert-box{background:rgba(255,23,68,.04);border:1px solid rgba(255,23,68,.25);
  border-radius:2px;padding:9px 13px;display:none;}
.alert-box.on{display:block;}
.alert-ttl{font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:700;color:var(--red);
  letter-spacing:.12em;text-transform:uppercase;animation:blink .8s ease-in-out infinite;
  margin-bottom:3px;text-shadow:var(--neon-red);}
.alert-msg{font-size:8.5px;color:rgba(255,23,68,.8);letter-spacing:.05em;}
.hrow{display:flex;justify-content:space-between;padding:3px 6px;border-bottom:1px solid rgba(0,229,255,.04);font-size:8.5px;color:rgba(0,229,255,.4);}
.hrow:last-child{border-bottom:none;}
.ht{color:#ff8f00;}.hh{color:#00b8d4;}.hs{color:#4caf50;}
.sensor-section{padding:0 20px 18px;}
.sec-hdr{display:flex;align-items:center;gap:12px;padding:14px 0 10px;
  border-top:1px solid rgba(0,229,255,.07);margin-bottom:10px;}
.sec-hdr::before{content:'';display:block;width:4px;height:24px;background:var(--green);
  border-radius:2px;box-shadow:var(--neon-green);}
.sec-hdr h2{font-family:'Rajdhani',sans-serif;font-size:17px;font-weight:700;color:#e0f7ff;
  letter-spacing:.12em;text-transform:uppercase;}
.sec-sub{font-size:9px;color:rgba(0,229,255,.4);letter-spacing:.12em;}
.sgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:9px;}
.scard{background:var(--panel);border:1px solid var(--border);border-radius:2px;padding:12px 14px;position:relative;transition:border-color .3s;}
.scard:hover{border-color:rgba(0,229,255,.28);}
.sacc{position:absolute;top:0;left:0;width:3px;height:100%;border-radius:2px 0 0 2px;}
.shdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px;}
.sid{font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:.08em;}
.sst{display:flex;align-items:center;gap:4px;font-size:8.5px;}
.svals{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;margin-bottom:7px;}
.sv{background:rgba(0,0,0,.22);border:1px solid rgba(0,229,255,.07);padding:6px 8px;text-align:center;}
.svl{font-size:7px;letter-spacing:.1em;color:rgba(0,229,255,.4);text-transform:uppercase;margin-bottom:1px;}
.svn{font-family:'Rajdhani',sans-serif;font-size:1.9rem;font-weight:700;line-height:1;}
.svu{font-size:7.5px;color:rgba(0,229,255,.4);}
.sftr{display:flex;justify-content:space-between;font-size:7.5px;color:rgba(0,229,255,.3);
  letter-spacing:.04em;padding-top:5px;border-top:1px solid rgba(0,229,255,.06);}
.srisk{font-size:8.5px;font-weight:bold;letter-spacing:.04em;}
.rn{color:var(--green);text-shadow:0 0 6px rgba(0,255,136,.4);}
.rw{color:var(--amber);text-shadow:0 0 6px rgba(255,171,64,.4);}
.rc{color:var(--red);text-shadow:0 0 6px rgba(255,23,68,.4);}
.coords-bar{display:flex;justify-content:space-between;align-items:center;padding:5px 20px;
  background:rgba(0,0,0,.25);border-top:1px solid var(--border);font-size:8.5px;
  color:rgba(0,229,255,.35);letter-spacing:.08em;flex-wrap:wrap;gap:6px;}
.specs{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);margin:0 20px 12px;}
.spec{background:var(--panel);padding:9px 12px;text-align:center;}
.spec-lbl{font-size:8px;letter-spacing:.18em;color:rgba(0,229,255,.4);text-transform:uppercase;margin-bottom:1px;}
.spec-val{font-family:'Rajdhani',sans-serif;font-size:17px;font-weight:700;color:var(--cyan);}
.spec-unit{font-size:9px;color:rgba(0,229,255,.5);margin-left:2px;}
.btm{padding:7px 20px;display:flex;justify-content:space-between;align-items:center;
  border-top:1px solid rgba(0,229,255,.07);font-size:9px;letter-spacing:.08em;
  color:rgba(0,229,255,.3);flex-wrap:wrap;gap:6px;}
.btm a{color:rgba(0,229,255,.5);text-decoration:none;transition:color .2s;}
.btm a:hover{color:var(--cyan);text-shadow:var(--neon-cyan);}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-tag">Institut Tecnològic de Barcelona — Parc de Collserola</div>
  <div class="hdr-title">Espurna IoT — Forest Fire Detection</div>
  <div class="hdr-sub">LoRaWAN EU868 · ChirpStack v4 · OTAA · AES-128 · Sensor Nodes</div>
  <div class="hdr-line"></div>
</div>

<div class="status-bar">
  <div style="display:flex;gap:16px;flex-wrap:wrap;">
    <div class="si"><div class="sdot dot-g"></div><span>ChirpStack: <span id="csStatus">CONNECTING...</span></span></div>
    <div class="si"><div class="sdot dot-g" id="gwDot"></div><span>Gateway: espurna-collserola-gw01</span></div>
    <div class="si"><div class="sdot dot-a" id="nodeDot"></div><span>Nodes: <span id="nodeStatus">en espera...</span></span></div>
  </div>
  <div style="display:flex;gap:10px;align-items:center;">
    <span id="lastUpdate">Last update: —</span>
    <button class="refresh-btn" onclick="fetchAllNodes()">⟳ REFRESH</button>
    <button class="refresh-btn" id="demoBtn" onclick="toggleDemo()" style="border-color:rgba(255,171,64,.4);color:var(--amber);">⚡ DEMO RAK-01</button>
  </div>
</div>

<div class="main">
  <div class="map-card">
    <div class="br"></div><div class="bl"></div>
    <div class="map-label">◈ ITB — PARC DE COLLSEROLA · LIVE MAP</div>
    <button class="edit-toggle" id="editToggle" onclick="toggleEditMode()">✎ MOURE NODES</button>
    <div class="edit-banner" id="editBanner">⚡ MODE EDICIÓ — Arrossega els nodes per canviar la posició</div>
    <div class="map-wrap">
      <div id="map"></div>
    </div>
  </div>

  <div class="right-panel">
    <div class="card card-l-cyan">
      <div class="card-title ct-c">◈ ChirpStack v4</div>
      <div class="drow"><span>SERVIDOR</span><span class="dval">192.168.244.1:8080</span></div>
      <div class="drow"><span>GATEWAY ID</span><span class="dval">ac1f09fffe1c63e1</span></div>
      <div class="drow"><span>GATEWAY STATUS</span><span class="dval r" id="csGwSt">OFFLINE</span></div>
      <div class="drow"><span>ACTIVACIÓ</span><span class="dval g">OTAA · JOINED</span></div>
      <div class="drow"><span>NODES ONLINE</span><span class="dval" id="csNodes">—</span></div>
      <div class="drow"><span>LAST JOIN</span><span class="dval" id="csJoin">—</span></div>
    </div>

    <div class="alert-box" id="alertBox">
      <div class="alert-ttl">⚠ ALERTA RISC D'INCENDI</div>
      <div class="alert-msg" id="alertMsg">—</div>
    </div>

    <div class="card card-l-green">
      <div class="card-title ct-g"><div class="live-dot"></div>DADES EN VIU</div>
      <div class="node-sel">
        <button class="nbtn active" onclick="selNode(0)" id="nb0">RAK-01</button>
        <button class="nbtn off" id="nb1">RAK-02</button>
        <button class="nbtn off" id="nb2">RAK-03</button>
        <button class="nbtn off" id="nb3">RAK-04</button>
        <button class="nbtn off" id="nb4">RAK-05</button>
      </div>
      <div class="mbig">
        <div class="mbig-lbl">Temperatura</div>
        <div class="mbig-val vt" id="mainT">—</div>
        <div class="mbig-unit">°C</div>
      </div>
      <div class="mrow">
        <div class="mmini"><div class="mmini-lbl">Hum. Aire</div><div class="mmini-val vh" id="mainH">—</div><div class="mmini-unit">% RH</div></div>
        <div class="mmini"><div class="mmini-lbl">Hum. Sòl</div><div class="mmini-val vs" id="mainS">—</div><div class="mmini-unit">% VWC</div></div>
      </div>
      <div class="drow" style="padding:4px 0;"><span>ESTAT</span><span class="dval g" id="riskSt">—</span></div>
      <div class="drow" style="padding:4px 0;"><span>UBICACIÓ</span><span class="dval" id="nodeCoords" style="font-size:8px;">—</span></div>
      <div class="drow" style="padding:4px 0;"><span>ÚLTIMA DADA FA</span><span class="dval" id="lastSeen">—</span></div>
      <div class="drow" style="padding:4px 0;"><span>FRAME COUNT</span><span class="dval" id="fCnt">—</span></div>
      <div class="drow" style="padding:4px 0;"><span>PROPER ENVIAMENT</span><span class="dval" id="nextTx" style="color:rgba(0,229,255,.5);">—</span></div>
    </div>

    <div class="card">
      <div class="card-title" style="color:rgba(0,229,255,.6);font-size:11px;padding-left:0;">Historial — <span id="histLbl">RAK-NODO-01</span></div>
      <div id="histList"><div class="hrow" style="color:rgba(0,229,255,.2);font-style:italic;"><span>Carregant...</span></div></div>
    </div>
  </div>
</div>

<div class="coords-bar">
  <span style="color:rgba(0,229,255,.5);letter-spacing:.12em;">NODES:</span>
  <span id="coordsAll">—</span>
  <span style="color:rgba(0,229,255,.25);">arrossega per reposicionar · zoom amb roda del ratolí</span>
</div>

<div class="sensor-section">
  <div class="sec-hdr">
    <h2>Telemetria en Viu</h2>
    <span class="sec-sub">— EU868 / ACTUALITZACIÓ: 1h</span>
    <div class="live-dot" style="margin-left:auto;"></div>
  </div>
  <div class="sgrid" id="sgrid"></div>
</div>

<div class="specs">
  <div class="spec"><div class="spec-lbl">Freqüència</div><div class="spec-val">868 <span class="spec-unit">MHz</span></div></div>
  <div class="spec"><div class="spec-lbl">Protocol</div><div class="spec-val" style="font-size:12px;">LoRaWAN</div></div>
  <div class="spec"><div class="spec-lbl">Activació</div><div class="spec-val" style="font-size:12px;">OTAA</div></div>
  <div class="spec"><div class="spec-lbl">Enviament</div><div class="spec-val" style="font-size:12px;">1h <span class="spec-unit">int</span></div></div>
  <div class="spec"><div class="spec-lbl">Payload</div><div class="spec-val">5 <span class="spec-unit">bytes</span></div></div>
</div>

<div class="btm">
  <span>Projecte Espurna · EspVRna · ITB ASIX2c 2025/2026</span>
  <span id="apiSt" style="color:rgba(0,229,255,.4);">API: inicialitzant...</span>
  <a href="http://192.168.244.1:8080" target="_blank">ChirpStack →</a>
</div>

<script>
// ══════════════════════════════════════
// CONFIG
// ══════════════════════════════════════
const CS  = 'http://192.168.244.1:8080';
const KEY = 'eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJhdWQiOiJjaGlycHN0YWNrIiwiaXNzIjoiY2hpcnBzdGFjayIsInN1YiI6ImQyYzQ4NTNkLWRhMzMtNDdhYS1iZWEwLWFiZmRkMTQyYWMzMCIsInR5cCI6ImtleSJ9.tdpGx6efktcmNd9c1RZeqogd7bCpPFamIwzo6xyrCKY';
const HDR = {'Authorization':'Bearer '+KEY,'Content-Type':'application/json'};
const OFFLINE_MS = 2 * 60 * 60 * 1000;

const GW = { label:'GW-ITB', lat:41.45318, lng:2.18622 };

const NODES = [
  { id:'RAK-NODO-01', devEUI:'ac1f09fffe245424', label:'RAK-01', lat:41.45352, lng:2.186453, deployed:true },
  { id:'RAK-NODO-02', devEUI:'ac1f09fffe245425', label:'RAK-02', lat:41.45347, lng:2.186441, deployed:true },
  { id:'RAK-NODO-03', devEUI:'ac1f09fffe245426', label:'RAK-03', lat:41.45342, lng:2.186429, deployed:true },
  { id:'RAK-NODO-04', devEUI:'ac1f09fffe245427', label:'RAK-04', lat:41.45337, lng:2.186417, deployed:true },
  { id:'RAK-NODO-05', devEUI:'ac1f09fffe245428', label:'RAK-05', lat:41.453111, lng:2.186475, deployed:true },
];

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
const nodeData = NODES.map(()=>({temp:null,hum:null,soil:null,fCnt:null,dr:null,time:null,rawTime:null,status:'waiting',history:[]}));
let selIdx=0, editMode=false, map, gwMarker;
const nodeMarkers=[], nodeCircles=[], nodeLines=[];

// Tracks last known rawTime per node to detect new packets
const lastKnownRawTime = NODES.map(() => null);

// Packet burst: per-node timer (ms remaining to show packets)
const TX_BURST_MS = 10000; // 10 seconds
const packetBurst = NODES.map(() => 0); // countdown ms per node

// Countdown ticker — updates every second
let countdownInterval = null;

// ══════════════════════════════════════
// NEON PACKET SYSTEM — Canvas inside leaflet-container
// ══════════════════════════════════════
let canvas, ctx;
let packets = [];
let rafId = null;
let lastRaf = 0;
let _canvasW = 0, _canvasH = 0;

const NEON_COLORS = [
  '#bf5fff', // lila neón intens
  '#e040fb', // magenta/porpra
  '#ff2d9b', // rosa neón
  '#7b2fff', // violeta profund
  '#00cfff', // cian elèctric
  '#a259ff', // lila suau
  '#ff6ec7', // rosa clar neón
];

function initCanvas() {
  // Inject canvas directly inside leaflet-container so
  // latLngToContainerPoint coords align perfectly
  const lc = map.getContainer();
  canvas = document.createElement('canvas');
  canvas.id = 'pktCanvas';
  canvas.style.cssText = 'position:absolute;top:0;left:0;pointer-events:none;z-index:650;';
  lc.appendChild(canvas);
  ctx = canvas.getContext('2d');
  syncCanvas();
}

function syncCanvas() {
  if (!canvas || !map) return;
  const lc = map.getContainer();
  const w = lc.offsetWidth;
  const h = lc.offsetHeight;
  if (!w || !h) return;
  if (_canvasW === w && _canvasH === h) return;
  _canvasW = w; _canvasH = h;
  const dpr = window.devicePixelRatio || 1;
  canvas.width  = Math.round(w * dpr);
  canvas.height = Math.round(h * dpr);
  canvas.style.width  = w + 'px';
  canvas.style.height = h + 'px';
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
}

function hexAlpha(hex, alpha) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${Math.max(0,Math.min(1,alpha)).toFixed(3)})`;
}

function easeInOut(t) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

function spawnPackets() {
  packets = [];
  const SPEED = 0.0025; // same speed for all — keeps spacing fixed
  NODES.forEach((cfg, i) => {
    if (!cfg.deployed) return;
    for (let p = 0; p < 3; p++) {
      packets.push({
        nodeIdx: i,
        t: p / 3,          // exactly 0, 0.333, 0.666 — equal distance forever
        speed: SPEED,
        color: NEON_COLORS[(i * 3 + p) % NEON_COLORS.length],
        radius: 3.5 + p * 0.4,
        trail: [],
      });
    }
  });
}

function rafLoop(ts) {
  rafId = requestAnimationFrame(rafLoop);
  if (ts - lastRaf < 32) return;
  const dt = Math.min(ts - lastRaf, 64);
  lastRaf = ts;

  syncCanvas();
  // Full context reset — prevents any state leaking into Leaflet's SVG layers
  ctx.globalAlpha = 1;
  ctx.globalCompositeOperation = 'source-over';
  ctx.clearRect(0, 0, _canvasW, _canvasH);

  // Decrement burst timers
  for (let i = 0; i < packetBurst.length; i++) {
    if (packetBurst[i] > 0) packetBurst[i] = Math.max(0, packetBurst[i] - dt);
  }

  packets.forEach(pkt => {
    const cfg = NODES[pkt.nodeIdx];
    const d   = nodeData[pkt.nodeIdx];
    const online = d && d.status === 'online' && isOnline(d.rawTime);
    // Only show packets during the burst window after a new transmission
    const active = online && packetBurst[pkt.nodeIdx] > 0;
    if (!active) { pkt.trail = []; return; }

    pkt.t += pkt.speed * (dt / 16);
    if (pkt.t >= 1) {
      pkt.t -= 1;
      pkt.trail = []; // wipe trail on wrap — no canvas pixels linger near gateway
    }
    const e  = easeInOut(pkt.t);
    const gw = map.latLngToContainerPoint([GW.lat, GW.lng]);
    const nd = map.latLngToContainerPoint([cfg.lat, cfg.lng]);

    const x = nd.x + (gw.x - nd.x) * e;
    const y = nd.y + (gw.y - nd.y) * e;

    // Fade in fast, fade out starting at t=0.72 so bolita is fully invisible before reaching gateway
    const alpha = pkt.t < 0.08 ? pkt.t / 0.08
                : pkt.t > 0.72 ? Math.max(0, 1 - (pkt.t - 0.72) / 0.28)
                : 1;

    // Trail
    pkt.trail.push({x, y});
    if (pkt.trail.length > 22) pkt.trail.shift();

    // Trail — fine glowing line
    if (pkt.trail.length > 1) {
      for (let k = 1; k < pkt.trail.length; k++) {
        const ta = (k / pkt.trail.length) * alpha;
        ctx.beginPath();
        ctx.moveTo(pkt.trail[k-1].x, pkt.trail[k-1].y);
        ctx.lineTo(pkt.trail[k].x,   pkt.trail[k].y);
        ctx.strokeStyle = hexAlpha(pkt.color, ta * 0.55);
        ctx.lineWidth   = pkt.radius * 0.5;
        ctx.lineCap     = 'round';
        ctx.stroke();
      }
    }

    // Neon glow — tight layers, intense color, no big halo
    const glows = [
      {r: pkt.radius * 3.5, a: 0.08},
      {r: pkt.radius * 2,   a: 0.20},
      {r: pkt.radius * 1.2, a: 0.55},
      {r: pkt.radius * 0.6, a: 0.95},
    ];
    glows.forEach(g => {
      ctx.beginPath();
      ctx.arc(x, y, g.r, 0, Math.PI * 2);
      ctx.fillStyle = hexAlpha(pkt.color, g.a * alpha);
      ctx.fill();
    });

    // Tiny white core
    ctx.beginPath();
    ctx.arc(x, y, pkt.radius * 0.3, 0, Math.PI * 2);
    ctx.fillStyle = hexAlpha('#ffffff', 0.95 * alpha);
    ctx.fill();
  });
}

function startRaf() {
  if (!rafId) { lastRaf = 0; rafId = requestAnimationFrame(rafLoop); }
}
function stopRaf() {
  if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
function timeSince(iso) {
  if (!iso) return null;
  const d = Date.now() - new Date(iso).getTime();
  if (d < 60000) return 'fa <1 min';
  if (d < 3600000) return 'fa ' + Math.floor(d/60000) + ' min';
  if (d < 86400000) return 'fa ' + Math.floor(d/3600000) + 'h';
  return 'fa ' + Math.floor(d/86400000) + 'd';
}
function isOnline(iso) { return iso && (Date.now() - new Date(iso).getTime()) < OFFLINE_MS; }

function decodePayload(b64) {
  try {
    const b = Array.from(atob(b64)).map(c=>c.charCodeAt(0));
    if (b.length < 5) return null;
    let tr = (b[0]<<8)|b[1]; if (tr>32767) tr-=65536;
    return {temp:tr/100, hum:((b[2]<<8)|b[3])/100, soil:b[4]};
  } catch(e) { return null; }
}

// ══════════════════════════════════════
// MAP
// ══════════════════════════════════════
function initMap() {
  map = L.map('map', {center:[GW.lat,GW.lng], zoom:18, zoomControl:true});
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution:'© <a href="https://www.openstreetmap.org/copyright">OSM</a> © <a href="https://carto.com/">CARTO</a>',
    subdomains:'abcd', maxZoom:20
  }).addTo(map);

  gwMarker = L.marker([GW.lat, GW.lng], {
    icon: L.divIcon({className:'',html:`<div class="gw-icon-wrap"><div class="gw-hex-icon"><div class="gw-dot"></div></div></div>`,iconSize:[30,30],iconAnchor:[15,15],popupAnchor:[0,-20]}),
    draggable:false, zIndexOffset:1000
  }).addTo(map);
  gwMarker.bindPopup(`
    <div class="popup-title">◈ ${GW.label} — RAK7289V2</div>
    <div class="popup-row"><span>ID</span><span class="popup-val">ac1f09fffe1c63e1</span></div>
    <div class="popup-row"><span>Estat</span><span class="popup-val" id="gwPopupSt" style="color:#444">○ OFFLINE</span></div>
    <div class="popup-row"><span>Freq.</span><span class="popup-val">868 MHz EU868</span></div>
    <div class="popup-row"><span>Ubicació</span><span class="popup-val">ITB — Pati interior</span></div>
    <div class="popup-coords">Lat: ${GW.lat.toFixed(6)} · Lng: ${GW.lng.toFixed(6)}</div>
  `);

  // Coverage rings
  const rings = [
    {r:15000, color:'#e040fb', w:2, dash:'12 6', fo:0.025},
    {r:10000, color:'#ce93d8', w:1.5, dash:'8 8', fo:0},
    {r:7500,  color:'#ce93d8', w:1.2, dash:'6 8', fo:0},
    {r:5000,  color:'#b39ddb', w:1,   dash:'5 7', fo:0},
    {r:2000,  color:'#b39ddb', w:1.5, dash:'4 5', fo:0.02},
  ];
  rings.forEach(ring => L.circle([GW.lat,GW.lng], {
    radius:ring.r, color:ring.color, weight:ring.w, dashArray:ring.dash,
    fillColor:ring.color, fillOpacity:ring.fo, opacity:0.6
  }).addTo(map));

  function rangeBadge(km, clr) {
    return `<div style="display:inline-flex;align-items:center;gap:5px;background:rgba(2,12,16,0.9);border:1px solid ${clr};padding:2px 8px 2px 6px;box-shadow:0 0 8px ${clr}44;">
      <div style="width:5px;height:5px;border-radius:50%;background:${clr};box-shadow:0 0 6px ${clr};"></div>
      <span style="font-family:'Share Tech Mono',monospace;font-size:9px;font-weight:bold;color:${clr};letter-spacing:0.18em;white-space:nowrap;">${km}</span>
    </div>`;
  }
  [
    [GW.lat+0.1348, GW.lng+0.005, '15 KM MAX', '#e040fb'],
    [GW.lat+0.0899, GW.lng+0.005, '10 KM',    '#ce93d8'],
    [GW.lat+0.0674, GW.lng+0.005, '7.5 KM',   '#ce93d8'],
    [GW.lat+0.0449, GW.lng+0.005, '5 KM',     '#b39ddb'],
    [GW.lat+0.018,  GW.lng+0.005, '2 KM',     '#b39ddb'],
  ].forEach(([lat,lng,km,clr]) =>
    L.marker([lat,lng], {icon:L.divIcon({className:'',html:rangeBadge(km,clr),iconAnchor:[45,10]})}).addTo(map)
  );

  NODES.forEach((_,i) => { if (NODES[i].deployed) createNodeMarker(i); });
  updateCoordsBar();

  // Init canvas inside leaflet container, then spawn packets & start loop
  map.whenReady(() => {
    initCanvas();
    spawnPackets();
    startRaf();
  });

  map.on('move zoom moveend zoomend', syncCanvas);
  window.addEventListener('resize', () => { _canvasW=0; _canvasH=0; syncCanvas(); map.invalidateSize(); });

  // Pause rAF when tab is hidden
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) stopRaf(); else startRaf();
  });
}

function makeNodeIcon(i) {
  const d = nodeData[i];
  const isCrit = d && d.temp > 40;
  const isWarn = d && (d.temp > 35 || (d.soil !== null && d.soil < 15));
  const cls = isCrit ? 'crit' : isWarn ? 'warn' : '';
  const rc  = isCrit ? '#ff1744' : isWarn ? '#ffab40' : '#00ff88';
  return L.divIcon({
    className:'',
    html:`<div class="node-icon-wrap"><div class="node-pulse-ring" style="border-color:${rc};box-shadow:0 0 8px ${rc}88,0 0 16px ${rc}44;"></div><div class="node-dot ${cls}"></div></div>`,
    iconSize:[36,36], iconAnchor:[18,18], popupAnchor:[0,-22]
  });
}

function offlineIcon() {
  return L.divIcon({
    className:'',
    html:`<div class="node-icon-wrap"><div style="position:relative;display:flex;align-items:center;justify-content:center;"><div style="position:absolute;width:26px;height:26px;border-radius:50%;border:1px dashed #333;opacity:.4;"></div><div style="width:10px;height:10px;border-radius:50%;background:rgba(40,40,40,.5);border:1.5px solid #333;"></div></div></div>`,
    iconSize:[20,20], iconAnchor:[10,10]
  });
}

function createNodeMarker(i) {
  const cfg = NODES[i];
  const marker = L.marker([cfg.lat,cfg.lng], {icon:offlineIcon(i), draggable:editMode, zIndexOffset:500}).addTo(map);
  marker.on('dragend', e => {
    const p = e.target.getLatLng();
    NODES[i].lat = p.lat; NODES[i].lng = p.lng;
    updateLines(); updateCoordsBar(); updateNodePopup(i);
    if (selIdx === i) document.getElementById('nodeCoords').textContent = p.lat.toFixed(6)+', '+p.lng.toFixed(6);
  });
  marker.on('click', () => selNode(i));
  const circle = L.circle([cfg.lat,cfg.lng], {radius:8, color:'#00ff88', weight:1, dashArray:'5 4', fillColor:'#00ff88', fillOpacity:0.03, opacity:0.3}).addTo(map);
  const line   = L.polyline([[cfg.lat,cfg.lng],[GW.lat,GW.lng]], {color:'#00e5ff', weight:1, dashArray:'4 8', opacity:.18}).addTo(map);
  nodeMarkers[i] = marker; nodeCircles[i] = circle; nodeLines[i] = line;
  updateNodePopup(i);
}

function updateNodePopup(i) {
  if (!nodeMarkers[i]) return;
  const cfg = NODES[i]; const d = nodeData[i];
  const online = d && d.rawTime && isOnline(d.rawTime);
  const stColor = online ? 'var(--green)' : 'rgba(80,80,80,.5)';
  const stTxt   = online ? '● ONLINE' : '○ OFFLINE';
  const isCrit  = d && d.temp > 40;
  const isWarn  = d && (d.temp > 35 || (d.soil !== null && d.soil < 15));
  const rtColor = isCrit ? 'var(--red)' : isWarn ? 'var(--amber)' : online ? 'var(--green)' : '#e0f7ff';
  const rt      = isCrit ? '⚠ CRÍTIC' : isWarn ? '⚠ MODERAT' : online ? '✓ NORMAL' : '—';
  nodeMarkers[i].bindPopup(`
    <div class="popup-title">◈ ${cfg.id}</div>
    <div class="popup-row"><span>Estat</span><span class="popup-val" style="color:${stColor}">${stTxt}</span></div>
    <div class="popup-row"><span>Temperatura</span><span class="popup-val">${d&&d.temp!==null?d.temp.toFixed(1)+' °C':'—'}</span></div>
    <div class="popup-row"><span>Hum. Aire</span><span class="popup-val">${d&&d.hum!==null?d.hum.toFixed(1)+' %':'—'}</span></div>
    <div class="popup-row"><span>Hum. Sòl</span><span class="popup-val">${d&&d.soil!==null?d.soil+' %':'—'}</span></div>
    <div class="popup-row"><span>Risc</span><span class="popup-val" style="color:${rtColor}">${rt}</span></div>
    <div class="popup-row"><span>Última dada</span><span class="popup-val">${timeSince(d?.rawTime)||'—'}</span></div>
    <div class="popup-coords">Lat: ${cfg.lat.toFixed(6)} · Lng: ${cfg.lng.toFixed(6)}</div>
  `);
}

function updateLines() {
  nodeMarkers.forEach((m,i) => {
    if (!m) return;
    const p = m.getLatLng();
    NODES[i].lat = p.lat; NODES[i].lng = p.lng;
    nodeLines[i]?.setLatLngs([[p.lat,p.lng],[GW.lat,GW.lng]]);
    nodeCircles[i]?.setLatLng([p.lat,p.lng]);
  });
}

function updateCoordsBar() {
  document.getElementById('coordsAll').innerHTML = NODES.map((c,i) =>
    `<span style="display:inline-flex;gap:4px;">
      <span style="color:rgba(0,255,136,.5)">N${i+1}:</span>
      <span style="color:rgba(0,229,255,.6)">${c.lat.toFixed(5)},${c.lng.toFixed(5)}</span>
      <span style="color:rgba(60,60,60,.5);font-size:8px">${c.deployed?'✓':'○'}</span>
    </span>`
  ).join('<span style="color:rgba(0,229,255,.08);margin:0 5px">|</span>');
}

function toggleEditMode() {
  editMode = !editMode;
  nodeMarkers.forEach(m => m && m.dragging[editMode ? 'enable' : 'disable']());
  document.getElementById('editToggle').classList.toggle('active', editMode);
  document.getElementById('editToggle').textContent = editMode ? '✓ GUARDAR' : '✎ MOURE NODES';
  document.getElementById('editBanner').classList.toggle('visible', editMode);
  if (!editMode) { updateLines(); updateCoordsBar(); nodeMarkers.forEach((_,i) => updateNodePopup(i)); }
}

// ══════════════════════════════════════
// API
// ══════════════════════════════════════
async function fetchNode(i) {
  try {
    const r = await fetch(`${CS}/api/devices/${NODES[i].devEUI}/events?limit=10`, {headers:HDR});
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const j = await r.json();
    const evs = j.result || [];
    let lastUp = null, lastJoin = null, fc = 0;
    for (const e of evs) {
      if (e.type === 'up' && !lastUp) lastUp = e;
      if (e.type === 'join' && !lastJoin) lastJoin = e;
      if (e.type === 'up') fc++;
    }
    if (lastJoin && i === 0) document.getElementById('csJoin').textContent = new Date(lastJoin.createdAt).toLocaleString('ca-ES');
    if (lastUp) {
      const pl = lastUp.data?.object; let dec = null;
      if (pl && pl.Temperatura !== undefined)
        dec = {temp:parseFloat(pl.Temperatura), hum:parseFloat(pl.Humedad_Aire), soil:parseInt(pl.Humedad_Suelo)};
      else if (lastUp.data?.data) dec = decodePayload(lastUp.data.data);
      if (dec) {
        const rawT = lastUp.createdAt;
        // Detect new transmission — rawTime changed since last poll
        if (rawT !== lastKnownRawTime[i]) {
          lastKnownRawTime[i] = rawT;
          packetBurst[i] = TX_BURST_MS; // trigger 10s burst
          // Reset packet positions so all 3 start together from node
          packets.filter(p => p.nodeIdx === i).forEach((p, idx) => {
            p.t = idx / 3;
            p.trail = [];
          });
        }
        nodeData[i] = {...dec, fCnt:lastUp.data?.fCnt||fc, dr:lastUp.data?.dr||0,
          time:new Date(rawT).toLocaleTimeString('ca-ES'), rawTime:rawT,
          status:isOnline(rawT)?'online':'offline', history:nodeData[i].history};
        nodeData[i].history.unshift({time:nodeData[i].time,...dec});
        if (nodeData[i].history.length > 6) nodeData[i].history.pop();
        return true;
      }
    }
    nodeData[i].status = 'waiting';
    return false;
  } catch(e) {
    nodeData[i].status = 'offline';
    return false;
  }
}

// Debounce guard so rapid clicks don't stack API calls
let fetchLock = false;
async function fetchAllNodes() {
  if (fetchLock) return;
  fetchLock = true;
  document.getElementById('apiSt').textContent = 'API: carregant... ⟳';
  try {
    const res = await Promise.all(NODES.map((_,i) => fetchNode(i)));
    const anyReal = res.some(Boolean);

    if (anyReal) {
      document.getElementById('csStatus').textContent = 'ONLINE';
      document.getElementById('csGwSt').textContent = 'ONLINE ●';
      document.getElementById('csGwSt').className = 'dval g';
      const gp = document.getElementById('gwPopupSt');
      if (gp) { gp.textContent = '● ONLINE'; gp.style.color = 'var(--green)'; }
      document.getElementById('apiSt').textContent = 'API: connectada ✓';
      document.getElementById('nodeDot').className = 'sdot dot-g';
    } else {
      document.getElementById('csStatus').textContent = 'OFFLINE';
      document.getElementById('csGwSt').textContent = 'OFFLINE';
      document.getElementById('csGwSt').className = 'dval r';
      const gp2 = document.getElementById('gwPopupSt');
      if (gp2) { gp2.textContent = '○ OFFLINE'; gp2.style.color = '#555'; }
      document.getElementById('apiSt').textContent = 'API: no accessible (cal estar al insti)';
      document.getElementById('nodeDot').className = 'sdot dot-r';
    }

    const onlineCount = nodeData.filter(d => d && d.status === 'online').length;
    document.getElementById('csNodes').textContent = `${onlineCount} online`;
    document.getElementById('nodeStatus').textContent = `${onlineCount} online / ${NODES.filter(n=>n.deployed).length} desplegats`;
    document.getElementById('lastUpdate').textContent = 'Last update: ' + new Date().toLocaleTimeString('ca-ES');

    updateMapMarkers();
    updateNodeButtons();
    selNode(selIdx);
    checkAlerts();
    renderGrid();
  } finally {
    fetchLock = false;
  }
}

// ══════════════════════════════════════
// UI UPDATE — separated from API calls
// ══════════════════════════════════════
function updateMapMarkers() {
  nodeMarkers.forEach((m, i) => {
    if (!m) return;
    const d = nodeData[i];
    const online = d && d.status === 'online' && isOnline(d.rawTime);
    const isCrit = d && d.temp > 40;
    const isWarn = d && (d.temp > 35 || (d.soil !== null && d.soil < 15));
    const color  = isCrit ? '#ff1744' : isWarn ? '#ffab40' : '#00ff88';

    if (online) {
      m.setIcon(makeNodeIcon(i));
      nodeCircles[i]?.setStyle({color, fillColor:color, opacity:.4, fillOpacity:.05});
      nodeLines[i]?.setStyle({color:'#00e5ff', opacity:.18, weight:1, dashArray:'4 8'});
    } else {
      m.setIcon(offlineIcon(i));
      nodeCircles[i]?.setStyle({opacity:0, fillOpacity:0});
      nodeLines[i]?.setStyle({opacity:0});
    }
    updateNodePopup(i);
  });
}

function updateNodeButtons() {
  for (let j = 0; j < 5; j++) {
    const btn = document.getElementById('nb'+j);
    if (!btn) continue;
    const d = nodeData[j];
    const online = d && d.status === 'online' && isOnline(d.rawTime);
    btn.className = 'nbtn' + (j === selIdx ? ' active' : '') + (!online ? ' off' : '');
  }
}

function selNode(i) {
  selIdx = i;
  updateNodeButtons();
  updateNextTxCountdown();
  const d = nodeData[i];
  const cfg = NODES[i];
  document.getElementById('histLbl').textContent = cfg.id;
  document.getElementById('nodeCoords').textContent = cfg.lat.toFixed(6)+', '+cfg.lng.toFixed(6);

  if (!d || d.temp === null || d.status === 'offline' || d.status === 'waiting') {
    document.getElementById('mainT').textContent = '—';
    document.getElementById('mainH').textContent = '—';
    document.getElementById('mainS').textContent = '—';
    const rEl = document.getElementById('riskSt');
    rEl.textContent = '—'; rEl.style.color = '#e0f7ff';
    document.getElementById('fCnt').textContent = '—';
    document.getElementById('lastSeen').textContent = '—';
    document.getElementById('histList').innerHTML =
      '<div class="hrow" style="color:rgba(60,60,60,.6);font-style:italic;"><span>'+
      (!cfg.deployed ? 'Sense dades (apagat o >2h)' : 'Esperant primera dada...')+
      '</span></div>';
    return;
  }

  const tEl = document.getElementById('mainT');
  tEl.textContent = d.temp.toFixed(1);
  tEl.className = 'mbig-val vt' + (d.temp > 40 ? ' hot' : '');
  document.getElementById('mainH').textContent = d.hum.toFixed(1);
  const sEl = document.getElementById('mainS');
  sEl.textContent = d.soil;
  sEl.className = 'mmini-val vs' + (d.soil < 15 ? ' dry' : '');
  document.getElementById('fCnt').textContent = d.fCnt || '—';
  document.getElementById('lastSeen').textContent = timeSince(d.rawTime) || d.time || '—';

  const rEl = document.getElementById('riskSt');
  if (d.temp > 40)                  { rEl.textContent = '⚠ RISC CRÍTIC';   rEl.style.color = 'var(--red)'; }
  else if (d.temp > 35 || d.soil < 15) { rEl.textContent = '⚠ RISC MODERAT'; rEl.style.color = 'var(--amber)'; }
  else                              { rEl.textContent = '✓ NORMAL';        rEl.style.color = 'var(--green)'; }

  const h = d.history || [];
  document.getElementById('histList').innerHTML = h.length
    ? h.map(r => `<div class="hrow">
        <span style="color:rgba(0,229,255,.3);font-size:8px;">${r.time}</span>
        <div style="display:flex;gap:7px;">
          <span class="ht">${r.temp.toFixed(1)}°C</span>
          <span class="hh">${typeof r.hum==='number'?r.hum.toFixed(0):r.hum}%</span>
          <span class="hs">${r.soil}%</span>
        </div></div>`).join('')
    : '<div class="hrow" style="color:rgba(0,229,255,.2);"><span>Sense historial</span></div>';
}

function checkAlerts() {
  const crit = nodeData.filter(d => d && d.temp > 40 && d.status === 'online');
  const warn = nodeData.filter(d => d && d.temp > 35 && d.temp <= 40 && d.status === 'online');
  const box  = document.getElementById('alertBox');
  if (crit.length) {
    box.classList.add('on'); box.style.borderColor = 'rgba(255,23,68,.3)';
    box.querySelector('.alert-ttl').textContent = "⚠ ALERTA RISC D'INCENDI";
    box.querySelector('.alert-ttl').style.color = 'var(--red)';
    document.getElementById('alertMsg').textContent = 'Temperatura crítica! Risc d\'incendi imminent.';
  } else if (warn.length) {
    box.classList.add('on'); box.style.borderColor = 'rgba(255,171,64,.3)';
    box.querySelector('.alert-ttl').textContent = '⚠ RISC MODERAT';
    box.querySelector('.alert-ttl').style.color = 'var(--amber)';
    document.getElementById('alertMsg').textContent = 'Temperatura elevada detectada.';
  } else {
    box.classList.remove('on');
  }
}

// renderGrid con DocumentFragment para evitar reflows
function renderGrid() {
  const container = document.getElementById('sgrid');
  const html = NODES.map((cfg, i) => {
    const d = nodeData[i];
    const online = d && d.status === 'online' && isOnline(d.rawTime);
    if (!online) {
      return `<div class="scard">
        <div class="sacc" style="background:rgba(40,40,40,.4)"></div>
        <div class="shdr">
          <span class="sid" style="color:rgba(60,60,60,.8)">${cfg.id}</span>
          <span class="sst" style="color:rgba(60,60,60,.6)">
            <span class="sdot" style="background:#222;box-shadow:none;"></span>OFFLINE
          </span>
        </div>
        <div class="svals">
          ${['Temp','Hum.Aire','Hum.Sòl'].map(l=>`<div class="sv"><div class="svl">${l}</div><div class="svn" style="color:rgba(40,40,40,.8);font-size:1.6rem;">—</div></div>`).join('')}
        </div>
        <div class="sftr"><span style="color:rgba(50,50,50,.6);font-size:8px;">Sense dades (apagat o >2h)</span></div>
      </div>`;
    }
    const isCrit = d.temp > 40, isWarn = d.temp > 35 || d.soil < 15;
    const acc = isCrit ? '#ff1744' : isWarn ? '#ffab40' : '#00ff88';
    const shadow = isCrit ? 'var(--neon-red)' : isWarn ? 'var(--neon-amber)' : 'var(--neon-green)';
    return `<div class="scard" style="border-color:${isWarn?'rgba(255,171,64,.25)':'var(--border)'}">
      <div class="sacc" style="background:${acc};box-shadow:0 0 10px ${acc}66"></div>
      <div class="shdr">
        <span class="sid" style="color:${acc};text-shadow:0 0 8px ${acc}88">${cfg.id}</span>
        <span class="sst" style="color:${acc}">
          <span class="sdot" style="background:${acc};box-shadow:0 0 6px ${acc},0 0 12px ${acc}66"></span>ONLINE
        </span>
      </div>
      <div class="svals">
        <div class="sv"><div class="svl">Temp</div><div class="svn" style="color:${isCrit?'#ff1744':'#ff8f00'}">${d.temp.toFixed(1)}</div><div class="svu">°C</div></div>
        <div class="sv"><div class="svl">Hum.Aire</div><div class="svn vh">${d.hum.toFixed(0)}</div><div class="svu">%</div></div>
        <div class="sv"><div class="svl">Hum.Sòl</div><div class="svn" style="color:${d.soil<15?'#ff6d00':'#4caf50'}">${d.soil}</div><div class="svu">%</div></div>
      </div>
      <div class="sftr">
        <span class="srisk ${isCrit?'rc':isWarn?'rw':'rn'}">${isCrit?'⚠ CRÍTIC':isWarn?'⚠ MODERAT':'✓ NORMAL'}</span>
        <span>${timeSince(d.rawTime)||d.time}</span>
        <span>FC:${d.fCnt||'—'}</span>
      </div>
    </div>`;
  }).join('');
  container.innerHTML = html;
}

// ══════════════════════════════════════
// DEMO MODE
// ══════════════════════════════════════
let demoInterval = null;
let demoActive = false;

function toggleDemo() {
  demoActive = !demoActive;
  const btn = document.getElementById('demoBtn');
  if (demoActive) {
    btn.textContent = '⏹ STOP DEMO';
    btn.style.borderColor = 'rgba(255,23,68,.4)';
    btn.style.color = 'var(--red)';
    runDemo();
    demoInterval = setInterval(runDemo, 8000);
  } else {
    btn.textContent = '⚡ DEMO RAK-01';
    btn.style.borderColor = 'rgba(255,171,64,.4)';
    btn.style.color = 'var(--amber)';
    clearInterval(demoInterval);
    nodeData[0] = {temp:null,hum:null,soil:null,fCnt:null,dr:null,time:null,rawTime:null,status:'offline',history:[]};
    updateDemoUI();
  }
}

function runDemo() {
  const base = {temp:27.3, hum:61, soil:48};
  const v = n => Math.round((n + (Math.random()-.5)*3) * 10) / 10;
  const now = new Date();
  const t = v(base.temp), h = Math.round(v(base.hum)), s = Math.round(v(base.soil));
  nodeData[0] = {
    temp:t, hum:h, soil:s,
    fCnt:18 + Math.floor(Math.random()*5),
    dr:0,
    time:now.toLocaleTimeString('ca-ES'),
    rawTime:now.toISOString(),
    status:'online',
    history:nodeData[0].history || []
  };
  nodeData[0].history.unshift({time:nodeData[0].time, temp:t, hum:h, soil:s});
  if (nodeData[0].history.length > 6) nodeData[0].history.pop();
  // Trigger burst — simulate a real transmission arriving
  packetBurst[0] = TX_BURST_MS;
  packets.filter(p => p.nodeIdx === 0).forEach((p, idx) => {
    p.t = idx / 3;
    p.trail = [];
  });
  updateDemoUI();
}

function updateDemoUI() {
  const d = nodeData[0];
  const online = d && d.status === 'online' && isOnline(d.rawTime);
  if (nodeMarkers[0]) {
    if (online) {
      nodeMarkers[0].setIcon(makeNodeIcon(0));
      nodeCircles[0]?.setStyle({color:'#00ff88',fillColor:'#00ff88',opacity:.4,fillOpacity:.05});
      nodeLines[0]?.setStyle({color:'rgba(0,229,255,.18)',opacity:.7});
    } else {
      nodeMarkers[0].setIcon(offlineIcon(0));
      nodeCircles[0]?.setStyle({opacity:0,fillOpacity:0});
      nodeLines[0]?.setStyle({opacity:0});
    }
    updateNodePopup(0);
  }
  const onlineCount = nodeData.filter(d => d && d.status === 'online' && isOnline(d.rawTime)).length;
  document.getElementById('csNodes').textContent = onlineCount + ' online';
  document.getElementById('nodeStatus').textContent = onlineCount + ' online / 5 desplegats';
  document.getElementById('lastUpdate').textContent = 'Last update: ' + new Date().toLocaleTimeString('ca-ES');
  if (online || !demoActive) {
    document.getElementById('csStatus').textContent = online ? 'ONLINE' : 'OFFLINE';
    document.getElementById('csGwSt').textContent = online ? 'ONLINE ●' : 'OFFLINE';
    document.getElementById('csGwSt').className = 'dval ' + (online ? 'g' : 'r');
    const gp = document.getElementById('gwPopupSt');
    if (gp) { gp.textContent = online ? '● ONLINE' : '○ OFFLINE'; gp.style.color = online ? 'var(--green)' : '#555'; }
  }
  updateNodeButtons();
  selNode(selIdx);
  checkAlerts();
  renderGrid();
}

// ══════════════════════════════════════
// NEXT TX COUNTDOWN — updates every second
// ══════════════════════════════════════
function updateNextTxCountdown() {
  const d = nodeData[selIdx];
  const el = document.getElementById('nextTx');
  if (!el) return;
  if (!d || !d.rawTime || d.status === 'offline' || d.status === 'waiting') {
    el.textContent = '—'; el.style.color = 'rgba(0,229,255,.35)'; return;
  }
  const TX_INTERVAL_MS = 60 * 60 * 1000; // 1 hour
  const elapsed = Date.now() - new Date(d.rawTime).getTime();
  const remaining = TX_INTERVAL_MS - elapsed;
  if (remaining <= 0) {
    el.textContent = 'imminent...';
    el.style.color = 'var(--amber)';
    return;
  }
  const mins = Math.floor(remaining / 60000);
  const secs = Math.floor((remaining % 60000) / 1000);
  el.textContent = `en ${mins}m ${secs.toString().padStart(2,'0')}s`;
  // Color shifts as it gets closer
  if (mins < 2)       { el.style.color = 'var(--amber)'; }
  else if (mins < 10) { el.style.color = 'rgba(0,229,255,.8)'; }
  else                { el.style.color = 'rgba(0,229,255,.45)'; }
}
initMap();
fetchAllNodes();
setInterval(fetchAllNodes, 300000);
setInterval(updateNextTxCountdown, 1000);
</script>
</body>
</html>
